# LAUNCH-1 W2 — release signing config TEMPLATE.
#
# Copy to `android/keystore.properties` (gitignored) and fill in real
# values. build.gradle reads it ONLY if it exists; absent → unsigned
# release + unaffected debug builds, so CI and other machines are fine.
#
# storeFile is resolved relative to the `android/` dir. Point it at the
# keystore OUTSIDE the repo so the secret never lands in git history.

storeFile=../../videx-release.keystore
storePassword=CHANGE_ME
keyAlias=videx
keyPassword=CHANGE_ME
