# TMDb API Key - https://www.themoviedb.org/settings/api
# Scripts-only since PLAT-2 (sync/enrichment pipelines) - NOT bundled into the client.
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# OMDB API Key - http://www.omdbapi.com/apikey.aspx
VITE_OMDB_API_KEY=your_omdb_api_key_here

# Streaming Availability API (Movie of the Night) - https://rapidapi.com/movie-of-the-night-movie-of-the-night-default/api/streaming-availability
# NOT prefixed with VITE_ — server-side only (sync scripts, Edge Functions). Never bundled into client code.
SA_API_KEY=your_rapidapi_key_here

# Supabase - https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # For sync scripts only — never expose in client code

# PLAT-2: videx-api Worker base URL. When set, all TMDb reads route
# through the proxy (key injected server-side) and the detail page uses
# the merged /v1/title endpoint. Unset = direct TMDb (rollback lever).
VITE_API_PROXY_URL=https://videx-api.your-subdomain.workers.dev
