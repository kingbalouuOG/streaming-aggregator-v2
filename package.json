{
  "name": "videx",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "debug-server": "node scripts/debug-server.js",
    "dev:debug": "node scripts/debug-server.js & npm run dev",
    "build": "vite build",
    "lint": "eslint .",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "build:android": "npm run build && npx cap sync android",
    "dev:android": "echo Run: set LIVE_RELOAD=YOUR_IP && npx cap sync android",
    "test:enrichment": "npx tsx scripts/enrichment/extract_fields.test.ts",
    "backfill:enrichment": "npx tsx scripts/enrichment/backfill-enrichment.ts",
    "test:embeddings": "npx tsx scripts/embeddings/__tests__/embeddingTemplate.test.ts",
    "backfill:embeddings": "npx tsx scripts/embeddings/backfill-embeddings.ts",
    "build:fingerprints": "npx tsx scripts/fingerprints/build-service-fingerprints.ts",
    "build:fingerprints:v2": "npx tsx scripts/fingerprints/build-service-fingerprints.ts --variant=exclusivity",
    "eval:fingerprints": "npx tsx scripts/fingerprints/eval-service-discrimination.ts",
    "eval:bottom-half-variance": "npx tsx scripts/fingerprints/eval-bottom-half-variance.ts",
    "check:cosine-drift": "npx tsx scripts/fingerprints/check-cosine-drift.ts",
    "preflight:tmdb-providers": "npx tsx scripts/fingerprints/preflight-tmdb-providers.ts",
    "backfill:tmdb-providers": "npx tsx scripts/fingerprints/backfill-tmdb-providers.ts",
    "test:fingerprints": "npx tsx scripts/fingerprints/__tests__/centroidMath.test.ts",
    "test:search": "npx tsx src/lib/search/__tests__/filterState.test.ts",
    "test:search-recents": "npx tsx src/lib/search/__tests__/recentSearches.test.ts",
    "test:contentcard-search-props": "npx tsx src/lib/search/__tests__/contentCardSearchProps.test.ts",
    "test:search-attribution": "npx tsx src/lib/taste-v2/__tests__/searchAttribution.test.ts",
    "eval:search-semantic": "npx tsx scripts/test/search-semantic-eval.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "^8.0.0",
    "@capacitor/app-launcher": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/network": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@supabase/supabase-js": "^2.97.0",
    "axios": "^1.13.5",
    "crypto-js": "^4.2.0",
    "lucide-react": "^0.487.0",
    "motion": "^12.34.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "@vitest/ui": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.4.1",
    "vitest": "^4.1.6"
  }
}
